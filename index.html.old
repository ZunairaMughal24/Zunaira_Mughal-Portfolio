      <div class="hero-glow glow-1"></div>
      <div class="hero-glow glow-2"></div>
    </div>
    <div class="hero-content">
      <div class="hero-tag reveal-up">
        <span class="dot"></span> Available for opportunities
      </div>
      <h1 class="hero-title reveal-up">
        <span class="title-line">Zunaira</span>
        <span class="title-line accent-line">Abdul Ghaffar</span>
      </h1>
      <p class="hero-role reveal-up">
        <span class="role-badge">Flutter Developer</span>
        <span class="role-divider">×</span>
        <span class="role-badge">Mobile App Specialist</span>
      </p>
      <p class="hero-desc reveal-up">
        Building scalable, production-quality cross-platform apps<br />
        with clean architecture & pixel-perfect UI.
      </p>
      <div class="hero-actions reveal-up">
        <a href="#projects" class="btn btn-primary">
          View My Work
          <svg width="16" height="16" viewBox="0 0 16 16" fill="none"><path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
        </a>
        <a href="#contact" class="btn btn-ghost">Let's Talk</a>
      </div>
      <div class="hero-stats reveal-up">
        <div class="stat">
          <span class="stat-num" data-target="5">0</span><span class="stat-unit">+</span>
          <span class="stat-label">Apps Shipped</span>
        </div>
        <div class="stat-divider"></div>
        <div class="stat">
          <span class="stat-num" data-target="3">0</span><span class="stat-unit">+</span>
          <span class="stat-label">Years Coding</span>
        </div>
        <div class="stat-divider"></div>
        <div class="stat">
          <span class="stat-num" data-target="4">0</span><span class="stat-unit">+</span>
          <span class="stat-label">Domains Covered</span>
        </div>
      </div>
    </div>
    <div class="hero-scroll">
      <span>Scroll</span>
      <div class="scroll-line"></div>
    </div>
